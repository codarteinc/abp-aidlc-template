name: Dependabot Auto-Merge
# Auto-merges Dependabot PRs after CICD succeeds, gated by the policy
# documented in CLAUDE.md "Dependabot policy" / docs/scaffold-runbook.md.
# Eligible: single-dep PRs whose title parses as `from X.Y.Z to A.B.C`,
# update-type is semver-patch or semver-minor, ecosystem is NOT
# `github-actions`, and the PR has no `do-not-merge` label. Everything
# else stays open for human review.
#
# This workflow itself runs on GitHub-hosted infrastructure
# (`runs-on: ubuntu-latest`) — it shells out to the gh CLI only, no
# self-hosted-runner dependency. Operators do NOT need to swap this file
# when migrating between self-hosted and GitHub-hosted CICD runners.
#
# Per-PR override: add the `do-not-merge` label to block auto-merge for
# a specific PR.
# Globally disable: rename this file to `dependabot-auto-merge.yml.disabled`.
# Required repo + org setting (one-time): Settings → Actions → General →
# Workflow permissions → "Allow GitHub Actions to create and approve
# pull requests" — ON at BOTH org and repo levels. Verify via:
#   gh api repos/<owner>/<repo>/actions/permissions/workflow
# `can_approve_pull_request_reviews` must be `true`.

on:
  workflow_run:
    workflows: ["CICD"]
    types: [completed]
  workflow_dispatch:
    inputs:
      pr_number:
        description: "PR number to evaluate for auto-merge (manual one-shot)"
        type: string
        required: true

permissions:
  contents: write
  pull-requests: write

concurrency:
  group: dependabot-auto-merge-${{ github.event.workflow_run.head_sha || github.event.inputs.pr_number }}
  cancel-in-progress: false

jobs:
  auto-merge:
    name: Auto-merge Dependabot PR
    runs-on: ubuntu-latest
    # Gate the entire job: must be either (a) a CICD success run triggered by
    # Dependabot on a pull_request event, OR (b) a manual workflow_dispatch.
    if: |
      github.event_name == 'workflow_dispatch' ||
      (
        github.event_name == 'workflow_run' &&
        github.event.workflow_run.event == 'pull_request' &&
        github.event.workflow_run.conclusion == 'success' &&
        github.event.workflow_run.actor.login == 'dependabot[bot]'
      )
    steps:
      - name: Resolve PR number
        id: pr
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          MANUAL_PR: ${{ github.event.inputs.pr_number }}
          HEAD_SHA: ${{ github.event.workflow_run.head_sha }}
        run: |
          set -euo pipefail
          if [ -n "${MANUAL_PR}" ]; then
            echo "number=${MANUAL_PR}" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          # Map workflow_run head_sha -> PR number via REST.
          PR_NUM=$(gh api "repos/${{ github.repository }}/commits/${HEAD_SHA}/pulls" \
            --jq '.[] | select(.state == "open") | .number' | head -n1)
          if [ -z "${PR_NUM}" ]; then
            echo "::warning::No open PR found for head_sha ${HEAD_SHA}; nothing to do."
            exit 0
          fi
          echo "number=${PR_NUM}" >> "$GITHUB_OUTPUT"

      - name: Load PR metadata + check kill-switch
        if: steps.pr.outputs.number != ''
        id: meta
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          PR_NUM: ${{ steps.pr.outputs.number }}
        run: |
          set -euo pipefail
          PR_JSON=$(gh pr view "${PR_NUM}" --repo "${{ github.repository }}" --json title,headRefName,labels,state,author)
          TITLE=$(echo "$PR_JSON" | jq -r .title)
          BRANCH=$(echo "$PR_JSON" | jq -r .headRefName)
          STATE=$(echo "$PR_JSON" | jq -r .state)
          AUTHOR=$(echo "$PR_JSON" | jq -r '.author.login // ""')
          AUTHOR_IS_BOT=$(echo "$PR_JSON" | jq -r '.author.is_bot // false')
          LABELS=$(echo "$PR_JSON" | jq -r '[.labels[].name] | join(",")')
          echo "title=${TITLE}"
          echo "branch=${BRANCH}"
          echo "state=${STATE}"
          echo "author=${AUTHOR}"
          echo "author_is_bot=${AUTHOR_IS_BOT}"
          echo "labels=${LABELS}"

          # Dependabot-origin gate: the workflow_run trigger already gates on
          # actor.login at the job level, but workflow_dispatch does not — this
          # belt-and-suspenders check ensures a manual `gh workflow run -f
          # pr_number=<NNN>` cannot auto-merge a non-Dependabot PR.
          #
          # Note: `gh pr view --json author` returns the gh-CLI identity form
          # (`app/dependabot` with `is_bot: true`), NOT the REST API form
          # (`dependabot[bot]`). Accept both representations so the check works
          # regardless of which identity surface is exposed in future gh CLI
          # versions.
          case "${AUTHOR}" in
            "dependabot[bot]"|"app/dependabot") ;;
            *)
              echo "::notice::PR #${PR_NUM} author is '${AUTHOR}' (not Dependabot) — skipping."
              echo "skip=non-dependabot" >> "$GITHUB_OUTPUT"
              exit 0
              ;;
          esac
          if ! echo "${BRANCH}" | grep -q '^dependabot/'; then
            echo "::notice::PR #${PR_NUM} head branch '${BRANCH}' is not a dependabot branch — skipping."
            echo "skip=non-dependabot-branch" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          if [ "${STATE}" != "OPEN" ]; then
            echo "::notice::PR #${PR_NUM} is not OPEN (state=${STATE}) — skipping."
            echo "skip=closed" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          if echo ",${LABELS}," | grep -q ',do-not-merge,'; then
            echo "::notice::PR #${PR_NUM} has 'do-not-merge' label — skipping."
            echo "skip=kill-switch" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          # Ecosystem from branch name: dependabot/<ecosystem>/...
          ECOSYSTEM=$(echo "${BRANCH}" | cut -d/ -f2)
          echo "ecosystem=${ECOSYSTEM}" >> "$GITHUB_OUTPUT"
          case "${ECOSYSTEM}" in
            github-actions|github_actions)
              echo "::notice::github-actions ecosystem bump — human review required."
              echo "skip=github-actions" >> "$GITHUB_OUTPUT"
              exit 0
              ;;
          esac

          # Grouped PRs (title: "bump the <name> group ...") have no version
          # info in the title and combine many deps. Conservative: skip.
          if echo "${TITLE}" | grep -qiE '^(chore\(deps[^)]*\): )?bump the .+ group'; then
            echo "::notice::Grouped Dependabot PR — human review required."
            echo "skip=grouped" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          # Single-dep PRs: extract from/to versions.
          # Title shapes:
          #   "Bump <name> from <X.Y.Z> to <A.B.C>"
          #   "chore(deps): bump <name> from <X.Y.Z> to <A.B.C> in /<dir>"
          #   "chore(deps-dev): bump <name> from <X.Y.Z> to <A.B.C> in /<dir>"
          FROM_VER=$(echo "${TITLE}" | grep -oE 'from [0-9]+\.[0-9]+\.[0-9]+' | head -n1 | sed 's/^from //')
          TO_VER=$(echo "${TITLE}"   | grep -oE 'to [0-9]+\.[0-9]+\.[0-9]+'   | head -n1 | sed 's/^to //')
          if [ -z "${FROM_VER}" ] || [ -z "${TO_VER}" ]; then
            echo "::notice::Could not parse semver from title '${TITLE}' — human review required."
            echo "skip=unparseable" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          FROM_MAJOR=$(echo "${FROM_VER}" | cut -d. -f1)
          TO_MAJOR=$(echo "${TO_VER}"     | cut -d. -f1)
          if [ "${FROM_MAJOR}" != "${TO_MAJOR}" ]; then
            echo "::notice::Major bump (${FROM_VER} → ${TO_VER}) — human review required."
            echo "skip=semver-major" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          FROM_MINOR=$(echo "${FROM_VER}" | cut -d. -f2)
          TO_MINOR=$(echo "${TO_VER}"     | cut -d. -f2)
          if [ "${FROM_MINOR}" != "${TO_MINOR}" ]; then
            UPDATE_TYPE="semver-minor"
          else
            UPDATE_TYPE="semver-patch"
          fi
          {
            echo "update-type=${UPDATE_TYPE}"
            echo "from-version=${FROM_VER}"
            echo "to-version=${TO_VER}"
            echo "skip="
          } >> "$GITHUB_OUTPUT"

      - name: Approve and merge
        if: steps.pr.outputs.number != '' && steps.meta.outputs.skip == ''
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          PR_NUM: ${{ steps.pr.outputs.number }}
          UPDATE_TYPE: ${{ steps.meta.outputs.update-type }}
          ECOSYSTEM: ${{ steps.meta.outputs.ecosystem }}
          FROM_VER: ${{ steps.meta.outputs.from-version }}
          TO_VER: ${{ steps.meta.outputs.to-version }}
        run: |
          set -euo pipefail
          echo "AUTO-MERGE eligible: PR #${PR_NUM} ${UPDATE_TYPE} (${FROM_VER} → ${TO_VER}) ecosystem=${ECOSYSTEM}"
          gh pr review "${PR_NUM}" --repo "${{ github.repository }}" --approve \
            --body "Auto-approved by dependabot-auto-merge (${UPDATE_TYPE}: ${FROM_VER} → ${TO_VER}, ecosystem=${ECOSYSTEM})."
          gh pr merge "${PR_NUM}"  --repo "${{ github.repository }}" --squash --delete-branch
