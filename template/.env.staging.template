# .env.staging.template — staging template.
#
# Render this to `.env.staging` (gitignored) on the VM. The deploy
# pipeline (.github/workflows/staging-deploy.yml) substitutes the
# ${VAR} placeholders at deploy time via `envsubst` with an explicit
# allowlist of variable names.
#
# Static defaults (APP_ENVIRONMENT, KNOWN_PROXY_CIDR, feature flags)
# are NOT in the allowlist — they ship literal.
#
# Load shape on the VM:
#   docker compose --env-file .env.staging \
#                  -f docker-compose.yml -f docker-compose.staging.yml ...
#
# NEVER commit a filled-in copy of this file.

# Drives ASPNETCORE_ENVIRONMENT inside the .NET containers AND the
# human-readable env label the SPA + Sentry see.
APP_ENVIRONMENT=Staging

# Image tags — pinned by the deploy pipeline to immutable SHA tags.
API_VERSION=${STAGING_API_VERSION}
WEB_VERSION=${STAGING_WEB_VERSION}
MIGRATOR_VERSION=${STAGING_MIGRATOR_VERSION}

# Public-facing URLs. Must be HTTPS in staging (Caddy auto-provisions).
API_PUBLIC_URL=${STAGING_API_PUBLIC_URL}
WEB_PUBLIC_URL=${STAGING_WEB_PUBLIC_URL}
APP_API_HOSTNAME=${STAGING_API_HOSTNAME}
APP_WEB_HOSTNAME=${STAGING_WEB_HOSTNAME}

# Tight CIDR matching docker-compose.yml's network ipam.config.
KNOWN_PROXY_CIDR=172.30.0.0/16

# ACME email — used by Let's Encrypt for expiration notices and the
# subscriber agreement. Required by Caddy for cert provisioning.
APP_ACME_EMAIL=${STAGING_ACME_EMAIL}

# Postgres password — high-entropy, rotated per environment.
DB_PASSWORD=${STAGING_DB_PASSWORD}

# Sentry DSN — leave empty to disable error reporting (Sentry SDK no-ops).
APP_SENTRY_DSN=${STAGING_SENTRY_DSN}

# CSP `connect-src` allowlist entry for Sentry ingest origin (the host
# the browser POSTs error reports to — derived from the DSN's hostname,
# e.g., `https://o123.ingest.sentry.io`). Leave empty when APP_SENTRY_DSN
# is empty.
APP_SENTRY_INGEST_ORIGIN=${STAGING_SENTRY_INGEST_ORIGIN}

# SPA feature flags (literal; no STAGING_* substitution).
APP_SHOW_SOCIAL_PROOF=false
APP_SHOW_ACTIVITY_FEED=false
