# .env — non-sensitive dev defaults for `docker compose up`.
#
# Override per-developer via shell env or a gitignored `.env.local`
# (compose reads .env first, then merges shell env on top).
# DO NOT put real secrets in this file — it is committed to the repo.

# Auto-load the dev overlay so plain `docker compose up` picks it up.
# Staging deploys must override on the command line:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml up
# (the -f flags take precedence over COMPOSE_FILE).
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# Drives ASPNETCORE_ENVIRONMENT inside the .NET containers AND the
# human-readable env label the SPA + Sentry see. One source of truth —
# dev compose = Development, staging compose = Staging.
APP_ENVIRONMENT=Development

# Public URLs the SPA + API agree on. HTTPS via Caddy's internal CA
# (Caddyfile.dev). Self-signed cert — use `curl -k` to bypass cert
# verification. Localhost-only by default; for remote-LXC dev,
# override with a hostname / IP in .env.local.
API_PUBLIC_URL=https://api.localhost
WEB_PUBLIC_URL=https://localhost
APP_API_HOSTNAME=api.localhost
APP_WEB_HOSTNAME=localhost

# Must match the project network subnet in docker-compose.yml.
KNOWN_PROXY_CIDR=172.30.0.0/16

# Sentry / ACME stay empty in dev — Sentry no-ops on empty DSN,
# ACME is disabled wholesale by Caddyfile.dev's internal CA.
APP_SENTRY_DSN=
APP_SENTRY_INGEST_ORIGIN=
APP_ACME_EMAIL=

# Dev DB password — NOT a secret. This Postgres is dev-only, the data
# directory is a named volume on the dev box, and the password gates a
# database that holds no real-user data. Committing it makes
# `docker compose up` work out-of-the-box after a fresh clone.
DB_PASSWORD=${PROJECT_NAME_LOWER}-dev

# Dev cert passphrase — required by Dockerfile.local's build-arg.
# Mints a `dotnet dev-certs https`-generated cert that no external
# system trusts. NOT a production secret.
OPENIDDICT_DEV_CERT_PASS=${PROJECT_NAME_LOWER}-dev-cert-pass
